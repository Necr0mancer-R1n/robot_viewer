<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="build_link" params="link_name">
    <link name="${link_name}">
      <visual>
        <geometry>
          <mesh filename="$(arg mesh_variant)"/>
        </geometry>
      </visual>
    </link>
  </xacro:macro>
</robot>
