<?xml version="1.0"?>
<robot name="missing_meshes_folder_fixture">
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="meshes/base_body.stl"/>
      </geometry>
    </visual>
  </link>

  <link name="arm_link">
    <visual>
      <geometry>
        <mesh filename="meshes/arm_body.stl"/>
      </geometry>
    </visual>
  </link>

  <joint name="arm_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>
</robot>
